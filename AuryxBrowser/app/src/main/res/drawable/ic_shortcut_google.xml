<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp"/>
            <solid android:color="#1C2638"/>
        </shape>
    </item>
    <item android:gravity="center">
        <shape android:shape="oval">
            <size android:width="34dp" android:height="34dp"/>
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>
    <item android:gravity="center" android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <rotate android:fromDegrees="0">
            <shape android:shape="ring" android:innerRadiusRatio="2.6" android:thickness="5dp" android:useLevel="false">
                <gradient android:type="sweep" android:colors="#4285F4,#34A853,#FBBC05,#EA4335,#4285F4"/>
            </shape>
        </rotate>
    </item>
</layer-list>
