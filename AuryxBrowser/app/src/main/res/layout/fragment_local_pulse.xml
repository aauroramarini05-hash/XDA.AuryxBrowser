<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="260dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Google Maps Hub"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Ricerca in zona con Maps + assistente AuryxAI ottimizzato per mappe"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <WebView
            android:id="@+id/wvMaps"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="12dp"
            android:background="@color/surface_elevated" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetectLocation"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:text="Rileva posizione GPS"
            android:textAllCaps="false"
            android:textColor="@color/background_dark"
            app:backgroundTint="@color/neon_green" />

        <TextView
            android:id="@+id/tvLocationStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Nessuna posizione acquisita"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvLocationStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Statistiche posizione in attesa"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Ricerche rapide su Google Maps"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearchRestaurants"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="Trova ristoranti in zona"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/surface_elevated" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearchFuel"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="Trova distributori vicini"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/surface_elevated" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearchHotels"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="Trova hotel in zona"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/surface_elevated" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearchPharmacies"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="Trova farmacie vicine"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/surface_elevated" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_auryx_ai"
                android:contentDescription="AuryxAI" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="AuryxAI (Gemini)"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/etAuryxAiPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_surface"
            android:hint="Es: suggeriscimi un hotel tranquillo vicino alla mia posizione"
            android:inputType="textMultiLine"
            android:minHeight="88dp"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAskAuryxAi"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="Chiedi ad AuryxAI"
            android:textAllCaps="false"
            android:textColor="@color/background_dark"
            app:backgroundTint="@color/neon_green" />

        <TextView
            android:id="@+id/tvAuryxAiOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Le risposte di AuryxAI appariranno qui"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
